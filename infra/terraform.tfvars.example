# Copy to terraform.tfvars and fill in.
project_id        = "your-gcp-project-id"
region            = "europe-west4" # EU; confirm Cloud Run GPU-on-Jobs (L4) is GA here
github_owner      = "xycu"
github_repository = "hegel-skill"

eval_reviewers = ["xycu"]

# Override if you bake different models into the eval image.
grader_model = "gemma2:9b-instruct-q4_0"
embed_model  = "nomic-embed-text"

# ENV_NAME = "secret-manager-secret-id"
eval_secrets = {}
